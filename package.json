{
  "name": "bloquin-server",
  "version": "1.0.0",
  "description": "Bloquin distributed compilation server",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start":        "node --env-file=.env src/index.js",
    "dev":          "node --env-file=.env --watch src/index.js",
    "build:client": "cd client && npm install && npm run build",
    "build":        "npm run build:client",
    "setup":        "bash scripts/setup.sh",
    "seed":         "node --experimental-sqlite scripts/seed.js",
    "test:load":    "node scripts/test-load.js",
    "test:errors":  "node scripts/test-errors.js",
    "test:all":     "node scripts/test-errors.js && node scripts/test-load.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "p-queue": "^9.1.2",
    "uuid": "^10.0.0",
    "ws": "^8.20.0"
  }
}
